# Required: PostgreSQL connection string. The engine creates the scan_results
# table on startup.
DATABASE_URL=postgres://user:password@localhost:5432/codescan?sslmode=disable

# Required: shared secret that gates the /api/scan endpoints. The frontend sends
# it as "Authorization: Bearer <BACKEND_API_KEY>". The server refuses to start
# without it, since the scan path is resource-intensive.
BACKEND_API_KEY=

# Optional: a GitHub token (PAT). When set, GitHub API calls are authenticated,
# raising the per-IP rate limit from 60/hr to 5000/hr. Public-repo read scope is
# enough; a private-repo scan uses the end user's OAuth token instead.
GITHUB_PUBLIC_TOKEN=

# Optional: comma-separated browser origins allowed to call the API (CORS).
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Optional: number of trusted reverse proxies in front of the engine, used to
# resolve the real client IP from X-Forwarded-For. Defaults to 1.
TRUSTED_PROXY_COUNT=1

# Optional: HTTP listen port. Defaults to 8080.
PORT=8080
